# Set this only when you intentionally need to test the live API-Sports call locally.
# APISPORTS_LIVE_DEV_REQUESTS=true
# Optional when the cached proxy lives on a different domain:
# VITE_SOCCER_TICKER_ENDPOINT=https://your-api-host.example.com/api/soccer-ticker
